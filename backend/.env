# Database Configuration
DATABASE_URL=postgresql://admin:password@localhost:5432/emotion_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Model Paths
MODEL_BASE_PATH=../emotion_detection_system/models
CNN_MODEL_FILE=cnn_model.keras
TEXT_MODEL_FILE=text_emotion_model.joblib
TFIDF_VECTORIZER_FILE=tfidf_vectorizer.joblib
HAAR_CASCADE_FILE=haarcascade_frontalface_default.xml

# Storage Configuration
UPLOAD_DIR=../emotion_detection_system/uploads
MAX_FILE_SIZE=16777216

# Logging
LOG_LEVEL=INFO
LOG_FILE=../emotion_detection_system/logs/api.log

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
